@model IEnumerable<SistemaGestionCitas.Controllers.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

        .page-header h2 {
            font-size: 1.4rem;
            font-weight: 800;
            color: #1a1a2e;
            margin: 0;
        }

            .page-header h2 span {
                color: #f97316;
            }

    .btn-primary-custom {
        background: linear-gradient(135deg,#0d6efd,#0056cc);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

        .btn-primary-custom:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13,110,253,0.35);
        }

    .data-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #f0f0f0;
        overflow: hidden;
    }

    .data-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .count-badge {
        background: #fdf4ff;
        color: #a855f7;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .search-box {
        position: relative;
        max-width: 280px;
    }

        .search-box i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            font-size: 0.9rem;
        }

        .search-box input {
            padding: 8px 12px 8px 34px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 0.85rem;
            width: 100%;
            transition: all 0.2s;
        }

            .search-box input:focus {
                border-color: #a855f7;
                outline: none;
                box-shadow: 0 0 0 3px rgba(168,85,247,0.1);
            }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table thead th {
            background: #f8fafc;
            padding: 12px 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #6c757d;
            border-bottom: 1px solid #f0f0f0;
        }

        .data-table tbody td {
            padding: 14px 20px;
            font-size: 0.88rem;
            color: #333;
            border-bottom: 1px solid #f8f8f8;
            vertical-align: middle;
        }

        .data-table tbody tr:hover {
            background: #fdf9ff;
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg,#a855f7,#7c3aed);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-email {
        font-weight: 600;
        color: #1a1a2e;
    }

    .badge-admin {
        background: #eff6ff;
        color: #1d4ed8;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .badge-user {
        background: #f8fafc;
        color: #475569;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .badge-active {
        background: #f0fdf4;
        color: #166534;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .badge-inactive {
        background: #fef2f2;
        color: #991b1b;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

        .action-btn:hover {
            transform: translateY(-1px);
        }

    .action-btn-edit {
        background: #fff7ed;
        color: #f97316;
    }

        .action-btn-edit:hover {
            background: #f97316;
            color: white;
        }

    .action-btn-delete {
        background: #fff0f0;
        color: #ef4444;
    }

        .action-btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #aaa;
    }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 12px;
            opacity: 0.4;
        }
</style>

<div class="page-header">
    <h2><i class="bi bi-person-gear me-2" style="color:#a855f7"></i>Gestión de <span>Usuarios</span></h2>
    <a asp-action="Create" class="btn-primary-custom">
        <i class="bi bi-person-plus"></i> Nuevo Usuario
    </a>
</div>

<div class="data-card">
    <div class="data-card-header">
        <span class="count-badge">
            <i class="bi bi-people me-1"></i>
            @Model.Count() usuarios
        </span>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Buscar usuario..." />
        </div>
    </div>

    <table class="data-table" id="usuariosTable">
        <thead>
            <tr>
                <th>Usuario</th>
                <th style="text-align:center">Rol</th>
                <th style="text-align:center">Estado</th>
                <th style="text-align:center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="user-avatar">
                                @u.Email.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <div class="user-email">@u.Email</div>
                                @if (u.Email == "admin@sistema.com")
                                {
                                    <small style="color:#aaa;font-size:0.72rem;">
                                        <i class="bi bi-shield-lock me-1"></i>Admin principal
                                    </small>
                                }
                            </div>
                        </div>
                    </td>
                    <td style="text-align:center">
                        @if (u.Rol == "Administrador")
                        {
                            <span class="badge-admin">
                                <i class="bi bi-shield-check"></i> Administrador
                            </span>
                        }
                        else
                        {
                            <span class="badge-user">
                                <i class="bi bi-person"></i> Usuario
                            </span>
                        }
                    </td>
                    <td style="text-align:center">
                        @if (u.Activo)
                        {
                            <span class="badge-active">
                                <i class="bi bi-check-circle-fill"></i> Activo
                            </span>
                        }
                        else
                        {
                            <span class="badge-inactive">
                                <i class="bi bi-x-circle-fill"></i> Inactivo
                            </span>
                        }
                    </td>
                    <td style="text-align:center">
                        <div style="display:flex;gap:6px;justify-content:center;">
                            <a asp-action="Edit" asp-route-id="@u.Id"
                               class="action-btn action-btn-edit" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (u.Email != "admin@sistema.com")
                            {
                                <a asp-action="Delete" asp-route-id="@u.Id"
                                   class="action-btn action-btn-delete" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4">
                        <div class="empty-state">
                            <i class="bi bi-people"></i>
                            <p>No hay usuarios registrados.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const term = this.value.toLowerCase();
            document.querySelectorAll('#usuariosTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
            });
        });
    </script>
}