@model IEnumerable<SistemaGestionCitas.Models.Cita>

@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-calendar-check"></i> Gestión de Citas</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Cita
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Servicio</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td>@cita.Cliente?.NombreCompleto</td>
                            <td>@cita.Servicio?.NombreServicio</td>
                            <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@DateTime.Today.Add(cita.Hora).ToString("hh:mm tt")</td>
                            <td>
                                @if (cita.Estado == SistemaGestionCitas.Models.EstadoCita.Programada)
                                {
                                    <span class="badge bg-success">Programada</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelada</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@cita.Id" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (cita.Estado == SistemaGestionCitas.Models.EstadoCita.Programada)
                                {
                                    <a asp-action="Edit" asp-route-id="@cita.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Cancelar" asp-route-id="@cita.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('¿Está seguro que desea cancelar esta cita?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No hay citas registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>