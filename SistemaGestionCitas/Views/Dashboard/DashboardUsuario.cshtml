@model SistemaGestionCitas.Controllers.DashboardUsuarioViewModel

@{
    ViewData["Title"] = "Mi Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-speedometer"></i> Mi Dashboard</h2>

    <!-- Tarjetas resumen -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-dark shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Mis Citas</h6>
                        <h2 class="fw-bold">@Model.TotalCitas</h2>
                    </div>
                    <i class="bi bi-calendar-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Citas Activas</h6>
                        <h2 class="fw-bold">@Model.CitasActivas</h2>
                    </div>
                    <i class="bi bi-calendar-event fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Citas Canceladas</h6>
                        <h2 class="fw-bold">@Model.CitasCanceladas</h2>
                    </div>
                    <i class="bi bi-calendar-x fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Próximas citas -->
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-clock"></i> Próximas Citas
                </div>
                <div class="card-body">
                    @if (Model.ProximasCitas.Any())
                    {
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Servicio</th>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cita in Model.ProximasCitas)
                                {
                                    <tr>
                                        <td>@cita.Cliente?.NombreCompleto</td>
                                        <td>@cita.Servicio?.NombreServicio</td>
                                        <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td>@DateTime.Today.Add(cita.Hora).ToString("hh:mm tt")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">No tenés citas próximas programadas.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Accesos rápidos -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-lightning"></i> Accesos Rápidos
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-controller="Citas" asp-action="Create" class="btn btn-outline-primary">
                        <i class="bi bi-calendar-plus"></i> Nueva Cita
                    </a>
                    <a asp-controller="Citas" asp-action="Index" class="btn btn-outline-dark">
                        <i class="bi bi-calendar-check"></i> Mis Citas
                    </a>
                    <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-success">
                        <i class="bi bi-person-check"></i> Clientes
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
