@model SistemaGestionCitas.Controllers.DashboardAdminViewModel

@{
    ViewData["Title"] = "Dashboard Administrativo";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard Administrativo</h2>

    <!-- Tarjetas de resumen -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Usuarios</h6>
                        <h2 class="fw-bold">@Model.TotalUsuarios</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Clientes</h6>
                        <h2 class="fw-bold">@Model.TotalClientes</h2>
                    </div>
                    <i class="bi bi-person-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Servicios Activos</h6>
                        <h2 class="fw-bold">@Model.TotalServiciosActivos</h2>
                    </div>
                    <i class="bi bi-gear fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-secondary shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Servicios Inactivos</h6>
                        <h2 class="fw-bold">@Model.TotalServiciosInactivos</h2>
                    </div>
                    <i class="bi bi-gear-fill fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Citas -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-dark shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total de Citas</h6>
                        <h2 class="fw-bold">@Model.TotalCitas</h2>
                    </div>
                    <i class="bi bi-calendar-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Citas Programadas</h6>
                        <h2 class="fw-bold">@Model.CitasProgramadas</h2>
                    </div>
                    <i class="bi bi-calendar-event fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Citas Canceladas</h6>
                        <h2 class="fw-bold">@Model.CitasCanceladas</h2>
                    </div>
                    <i class="bi bi-calendar-x fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Top 3 Servicios -->
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning fw-bold">
                    <i class="bi bi-trophy"></i> Top 3 Servicios más Solicitados
                </div>
                <div class="card-body">
                    @if (Model.TopServicios.Any())
                    {
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Servicio</th>
                                    <th class="text-center">Citas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopServicios.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            @if (i == 0)
                                            {
                                                <span class="badge bg-warning text-dark">🥇</span>
                                            }
                                            else if (i == 1)
                                            {

                                                <span class="badge bg-secondary">🥈</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-danger">🥉</span>
                                            }
                                        </td>
                                        <td>@Model.TopServicios[i].NombreServicio</td>
                                        <td class="text-center fw-bold">@Model.TopServicios[i].TotalCitas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">No hay citas registradas aún.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Accesos rápidos -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-lightning"></i> Accesos Rápidos
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-people"></i> Gestionar Usuarios
                    </a>
                    <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-success">
                        <i class="bi bi-person-check"></i> Gestionar Clientes
                    </a>
                    <a asp-controller="Servicios" asp-action="Index" class="btn btn-outline-info">
                        <i class="bi bi-gear"></i> Gestionar Servicios
                    </a>
                    <a asp-controller="Citas" asp-action="Index" class="btn btn-outline-dark">
                        <i class="bi bi-calendar-check"></i> Ver Todas las Citas
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
