@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Sistema de Citas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="logo" href="~/images/calendario.png" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a3a5c 0%, #0d6efd 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

            /* Círculos decorativos de fondo */
            body::before {
                content: '';
                position: fixed;
                width: 500px;
                height: 500px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                top: -100px;
                left: -100px;
                animation: pulse 6s ease-in-out infinite;
            }

            body::after {
                content: '';
                position: fixed;
                width: 350px;
                height: 350px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                bottom: -80px;
                right: -80px;
                animation: pulse 8s ease-in-out infinite reverse;
            }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }
        }

        .login-wrapper {
            display: flex;
            width: 920px;
            min-height: 540px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.35);
            position: relative;
            z-index: 1;
        }

        /* ---- Panel izquierdo (ilustración) ---- */
        .login-left {
            flex: 1.1;
            background: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 50px 40px;
            position: relative;
            overflow: hidden;
        }

        /* Figuras geométricas decorativas */
        .shape {
            position: absolute;
            border-radius: 50%;
            opacity: 0.12;
        }

        .shape-1 {
            width: 180px;
            height: 180px;
            background: #0d6efd;
            top: -40px;
            right: -40px;
        }

        .shape-2 {
            width: 100px;
            height: 100px;
            background: #0d6efd;
            bottom: 30px;
            left: -20px;
        }

        .shape-3 {
            width: 60px;
            height: 60px;
            background: #198754;
            bottom: 100px;
            right: 20px;
        }

        /* Triángulos y puntos decorativos */
        .dot {
            position: absolute;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 3px solid;
        }

        .dot-1 {
            border-color: #0d6efd;
            top: 80px;
            left: 40px;
            animation: bounce 3s infinite;
        }

        .dot-2 {
            border-color: #198754;
            bottom: 80px;
            right: 50px;
            animation: bounce 4s infinite reverse;
        }

        .dot-3 {
            border-color: #ffc107;
            top: 50%;
            left: 20px;
            animation: bounce 5s infinite;
        }

        .triangle {
            position: absolute;
            width: 0;
            height: 0;
            opacity: 0.25;
        }

        .triangle-1 {
            border-left: 12px solid transparent;
            border-right: 12px solid transparent;
            border-bottom: 20px solid #0d6efd;
            top: 60px;
            right: 60px;
            animation: float 4s ease-in-out infinite;
        }

        .triangle-2 {
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-bottom: 14px solid #198754;
            bottom: 120px;
            left: 50px;
            animation: float 6s ease-in-out infinite reverse;
        }

        @@keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-8px);
            }
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0) rotate(0deg);
            }

            50% {
                transform: translateY(-12px) rotate(10deg);
            }
        }

        /* Ilustración central */
        .illustration-circle {
            width: 200px;
            height: 200px;
            background: linear-gradient(135deg, #e8f0fe, #c2d4f8);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 28px;
            animation: float 4s ease-in-out infinite;
            box-shadow: 0 10px 40px rgba(13,110,253,0.2);
        }

            .illustration-circle i {
                font-size: 90px;
                color: #0d6efd;
            }

        .login-left h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1a1a2e;
            text-align: center;
            margin-bottom: 8px;
        }

        .login-left p {
            color: #6c757d;
            font-size: 0.88rem;
            text-align: center;
            line-height: 1.6;
            max-width: 260px;
        }

        /* ---- Panel derecho (formulario) ---- */
        .login-right {
            flex: 1;
            background: white;
            border-left: 1px solid #f0f0f0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 50px 45px;
        }

        .brand-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #e8f0fe;
            color: #0d6efd;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .login-right h2 {
            font-size: 1.7rem;
            font-weight: 800;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .login-right .subtitle {
            color: #6c757d;
            font-size: 0.88rem;
            margin-bottom: 30px;
        }

        .form-label {
            font-weight: 600;
            color: #444;
            font-size: 0.85rem;
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
            margin-bottom: 18px;
        }

            .input-wrap .icon-left {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #0d6efd;
                font-size: 1rem;
            }

            .input-wrap input {
                width: 100%;
                padding: 12px 14px 12px 40px;
                border: 1.5px solid #dee2e6;
                border-radius: 12px;
                font-size: 0.92rem;
                transition: all 0.3s;
                background: #fafafa;
                color: #333;
            }

                .input-wrap input:focus {
                    border-color: #0d6efd;
                    box-shadow: 0 0 0 4px rgba(13,110,253,0.1);
                    outline: none;
                    background: white;
                }

            .input-wrap .icon-right {
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                cursor: pointer;
                color: #aaa;
                font-size: 1rem;
            }

                .input-wrap .icon-right:hover {
                    color: #0d6efd;
                }

        .btn-login {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #0d6efd, #0056cc);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: all 0.3s;
            margin-top: 6px;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(13,110,253,0.4);
                color: white;
            }

        .alert-danger {
            border-radius: 10px;
            font-size: 0.85rem;
            padding: 10px 14px;
            margin-bottom: 18px;
            border: none;
            background: #fff0f0;
            color: #dc3545;
        }

        .divider {
            border-top: 1px solid #f0f0f0;
            margin: 24px 0 16px;
        }

        .footer-text {
            text-align: center;
            font-size: 0.78rem;
            color: #bbb;
        }

        @@media (max-width: 768px) {
            .login-wrapper {
                flex-direction: column;
                width: 95%;
                min-height: auto;
            }

            .login-left {
                padding: 35px 25px;
            }

            .illustration-circle {
                width: 130px;
                height: 130px;
            }

                .illustration-circle i {
                    font-size: 60px;
                }

            .login-right {
                padding: 35px 25px;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- Panel izquierdo -->
        <div class="login-left">
            <!-- Formas decorativas -->
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="dot dot-1"></div>
            <div class="dot dot-2"></div>
            <div class="dot dot-3"></div>
            <div class="triangle triangle-1"></div>
            <div class="triangle triangle-2"></div>

            <img src="~/images/LOGO-UISIL.png" alt="UISIL"
                 style="width: 220px; margin-bottom: 28px; animation: float 4s ease-in-out infinite;" />

            <h2>Bienvenido al Sistema</h2>
            <p>Gestioná citas, clientes y servicios de forma eficiente desde un solo lugar.</p>
        </div>

        <!-- Panel derecho -->
        <div class="login-right">
            <div class="brand-badge">
                <i class="bi bi-shield-check"></i> UISIL &mdash; ISB-16
            </div>

            <h2>Inicio de sesión</h2>
            <p class="subtitle">Ingresá tus credenciales para acceder al sistema</p>

            <form method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        Correo o contraseña incorrectos.
                    </div>
                }

                <label class="form-label">Correo electrónico</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope icon-left"></i>
                    <input asp-for="Input.Email"
                           type="email"
                           placeholder="correo@ejemplo.com"
                           autocomplete="username" />
                </div>

                <label class="form-label">Contraseña</label>
                <div class="input-wrap">
                    <i class="bi bi-lock icon-left"></i>
                    <input asp-for="Input.Password"
                           type="password"
                           id="passwordInput"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <i class="bi bi-eye icon-right" id="togglePassword"></i>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Entrar
                </button>
            </form>

            <div class="divider"></div>
            <p class="footer-text">&copy; 2026 Sistema de Gestión de Citas &mdash; Todos los derechos reservados</p>
        </div>
    </div>

    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            if (input.type === 'password') {
                input.type = 'text';
                this.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                this.classList.replace('bi-eye-slash', 'bi-eye');
            }
        });
    </script>
</body>
</html>